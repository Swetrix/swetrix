  "scripts": {
    "deploy": "npm run prebuild && node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js build cloud && mv apps/cloud/dist dist",
    "deploy:community": "npm run prebuild && node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js build community && mv apps/community/dist dist",
    "refresh-submodules": "git submodule update --remote -- blog-posts/",
    "init-submodules": "git submodule update --init --recursive",
    "prebuild": "rimraf dist",
    "build": "npm run refresh-submodules && node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js build cloud && mv apps/cloud/dist dist && npm run sentry:sourcemaps",
    "build:no-submodules-refresh": "node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js build cloud && mv apps/cloud/dist dist && npm run sentry:sourcemaps",
    "postbuild": "cp .env dist/.env",
    "format": "oxfmt --write apps/community/src apps/cloud/src",
    "format:check": "oxfmt --check apps/community/src apps/cloud/src",
    "clickhouse:initialise": "node migrations/clickhouse/initialise_selfhosted.js",
    "start": "cross-env NODE_ENV=development nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:community": "cross-env NODE_ENV=development nest start community --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "npm run clickhouse:initialise && cross-env NODE_ENV=cloud node dist/main",
    "lint": "oxlint apps/cloud/src apps/community/src",
    "lint:fix": "oxlint --fix apps/cloud/src apps/community/src",
    "lint:tsc": "tsc --noEmit",
    "find-deadcode": "ts-prune",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org swetrix --project swetrix-api ./dist && sentry-cli sourcemaps upload --org swetrix --project swetrix-api ./dist",
    "knip": "knip"
  },
  "dependencies": {
